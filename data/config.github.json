{
  "version": "1.0",
  "ai": {
    "provider": "gemini",
    "model": "gemini-2.5-flash",
    "api_key_env": "GOOGLE_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 1,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": ["zh"]
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "xxx@qq.com",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "anthropics",
        "repo": "anthropic-sdk-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "deepseek-ai",
        "repo": "DeepSeek-V3",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 50
    },
    "rss": [
      {
        "name": "机器之心",
        "url": "https://www.jiqizhixin.com/rss",
        "enabled": true,
        "category": "ai-zh"
      },
      {
        "name": "量子位",
        "url": "https://www.qbitai.com/rss",
        "enabled": true,
        "category": "ai-zh"
      },
      {
        "name": "36氪",
        "url": "https://36kr.com/feed",
        "enabled": true,
        "category": "tech-zh"
      },
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/blog/rss.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Anthropic Blog",
        "url": "https://www.anthropic.com/blog/rss.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Google DeepMind Blog",
        "url": "https://deepmind.google/blog/rss.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "MIT Technology Review AI",
        "url": "https://www.technologyreview.com/feed/",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "TechCrunch AI",
        "url": "https://techcrunch.com/category/artificial-intelligence/feed/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "ai"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 20,
          "min_score": 30
        },
        {
          "subreddit": "artificial",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 10
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 10
        },
        {
          "subreddit": "ChatGPT",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 20
        }
      ],
      "users": [],
      "fetch_comments": 3
    },
    "twitter": {
      "enabled": false
    },
    "openbb": {
      "enabled": false
    },
    "ossinsight": {
      "enabled": false
    }
  },
  "filtering": {
    "ai_score_threshold": 4.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": false
  }
}
